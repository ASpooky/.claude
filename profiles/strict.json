{
  "description": "コミット前の厳格チェック。console.log・TODO 検出 + TypeScript エラーがあればブロック。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/strict-commit-check.js"
          }
        ]
      }
    ]
  }
}
